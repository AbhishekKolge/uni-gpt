{
  "name": "@uni-gpt/db",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "postinstall": "prisma generate",
    "db:studio": "prisma studio",
    "db:setup": "prisma db execute --file ./prisma/sql/0001_enable_pgvector.sql --schema ./prisma/schema",
    "check-types": "tsc -b"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "catalog:",
    "@uni-gpt/env": "workspace:*",
    "dotenv": "catalog:",
    "pg": "^8.17.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/pg": "^8.16.0",
    "@uni-gpt/config": "workspace:*",
    "prisma": "^7.8.0",
    "typescript": "catalog:"
  }
}
