# Web environment — copy to `apps/web/.env` and fill in real values.
# Source of truth / validation: packages/env/src/web.ts.
# Do NOT commit the real .env (it is gitignored); only this .env.example is committed.

# Server URL. In dev the browser uses same-origin paths (/trpc, /api/auth, /api/chat) via Next
# rewrites, so this is only used for SSR / Docker (in Docker it is http://server:3000).
NEXT_PUBLIC_SERVER_URL="http://localhost:3000"

# Optional — set to 1 to skip zod env validation.
# SKIP_ENV_VALIDATION=
