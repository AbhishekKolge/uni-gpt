# Server environment — copy to `apps/server/.env` and fill in real values.
# Source of truth / validation: packages/env/src/server.ts (server fails fast on a missing required var).
# Full var list as phases land: spec Appendix A.7 (docs/superpowers/specs/2026-06-18-uni-gpt-design.md).
# Do NOT commit the real .env (it is gitignored); only this .env.example is committed.

# Postgres connection string. Database must be pgvector-capable (run `pnpm -F @uni-gpt/db db:setup`).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/uni_gpt"

# better-auth signing secret — MIN 32 chars. Generate one: `openssl rand -base64 32`
BETTER_AUTH_SECRET="replace-with-a-32-plus-character-random-secret"

# Base URL of THIS server (better-auth issuer / callback base).
BETTER_AUTH_URL="http://localhost:3000"

# Polar (sandbox) access token — billing. From the Polar sandbox dashboard.
POLAR_ACCESS_TOKEN="polar_oat_replace_me"

# URL Polar redirects to after a successful checkout.
POLAR_SUCCESS_URL="http://localhost:3001/dashboard"

# Allowed browser origin for CORS (the web app).
CORS_ORIGIN="http://localhost:3001"

# Resend (transactional email: verify / reset / delete-account). Key from resend.com.
RESEND_API_KEY="re_replace_me"
# Verified sender; the resend.dev default works for testing without a verified domain.
RESEND_FROM="uni-gpt <onboarding@resend.dev>"

# Google OAuth client (Google Cloud Console). Redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID="replace_me.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-replace_me"

# Passkey relying-party. rpID = registrable domain (localhost in dev, apex in prod);
# origin = full web origin. Mismatch silently breaks WebAuthn registration.
PASSKEY_RP_ID="localhost"
PASSKEY_RP_NAME="uni-gpt"
PASSKEY_ORIGIN="http://localhost:3001"

# Optional — defaults to "development". One of: development | production | test.
# NODE_ENV="development"

# Optional — set to 1 to skip zod env validation (e.g. during a Docker build).
# SKIP_ENV_VALIDATION=
