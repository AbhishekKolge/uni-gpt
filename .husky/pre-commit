#!/bin/sh
# Pre-commit: format + lint (ultracite/biome) on staged files, then type-check.

# `|| true`: grep exits 1 when no staged file matches (e.g. a .prisma- or
# .md-only commit). Husky runs this hook under `sh -e`, so an unguarded
# non-zero grep aborts the whole hook before type-checking ever runs.
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(ts|tsx|js|jsx|mjs|cjs|json|jsonc|css)$' || true)

if [ -n "$STAGED_FILES" ]; then
  # 1. Format + auto-fix lint on staged files only (fast)
  FIX_EXIT_CODE=0
  echo "$STAGED_FILES" | xargs pnpm exec ultracite fix || FIX_EXIT_CODE=$?

  # Re-stage anything the formatter rewrote
  echo "$STAGED_FILES" | while IFS= read -r file; do
    [ -f "$file" ] && git add -- "$file"
  done

  if [ "$FIX_EXIT_CODE" -ne 0 ]; then
    echo "✗ ultracite reported unfixable lint errors — commit aborted"
    exit "$FIX_EXIT_CODE"
  fi
fi

# 2. Type-check the whole workspace (turbo-cached; only changed packages re-run)
echo "▶ check-types..."
pnpm check-types || { echo "✗ type errors — commit aborted"; exit 1; }

echo "✨ format + lint + types OK"
